<Window x:Class="HyperCompressDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HyperCompress Test Suite" Height="600" Width="800"
        Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🧪 HyperCompress Test Suite" 
                   FontSize="24" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,20"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="TestEncodersButton" Content="Test Encoders" Click="TestEncoders_Click" 
                    Padding="15,8" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" 
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="TestArchiveButton" Content="Test Archive" Click="TestArchive_Click" 
                    Padding="15,8" Margin="0,0,10,0" Background="#2196F3" Foreground="White" 
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="ClearLogButton" Content="Clear Log" Click="ClearLog_Click" 
                    Padding="15,8" Margin="0,0,10,0" Background="#FF9800" Foreground="White" 
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="CopyLogButton" Content="Copy Log" Click="CopyLog_Click" 
                    Padding="15,8" Background="#9C27B0" Foreground="White" 
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
        
        <!-- Log Viewer -->
        <Border Grid.Row="2" Background="#2D2D2D" BorderBrush="#555" BorderThickness="1" Padding="10">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogTextBlock" 
                           TextWrapping="Wrap" 
                           FontFamily="Consolas" 
                           FontSize="12" 
                           Foreground="#E0E0E0"/>
            </ScrollViewer>
        </Border>
        
        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#252525" Padding="10" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="#4CAF50" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
