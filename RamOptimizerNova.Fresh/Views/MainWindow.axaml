<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RamOptimizerNova.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="RamOptimizerNova.Views.MainWindow"
        x:CompileBindings="False"
        Icon="/Assets/avalonia-logo.ico"
        Title="RAM Optimizer Nova"
        Width="1400" Height="900"
        Background="{DynamicResource SpaceDark}"
        WindowStartupLocation="CenterScreen">

    <TabControl Background="Transparent" Padding="0">
        
        <!-- DASHBOARD TAB -->
        <TabItem Header="📊 Dashboard">
            <ScrollViewer>
                <StackPanel Margin="40" Spacing="32">
                    
                    <!-- Header -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="System Overview" 
                                  FontSize="36" 
                                  FontWeight="Bold"
                                  Foreground="{DynamicResource StarWhite}"/>
                        <TextBlock Text="Real-time performance metrics and system health"
                                  FontSize="14"
                                  Foreground="{DynamicResource StarDim}"/>
                    </StackPanel>
                    
                    <!-- Quick Stats Grid (CPU, GPU, RAM) -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="16">
                        
                        <!-- CPU Card -->
                        <Border Grid.Column="0" 
                               Background="#99000000" 
                               BorderBrush="#19FFFFFF"
                               BorderThickness="1"
                               CornerRadius="16"
                               Padding="24">
                            <StackPanel Spacing="12">
                                <TextBlock Text="CPU Usage" 
                                          FontSize="14" 
                                          FontWeight="Bold"
                                          Foreground="{DynamicResource StarDim}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="CpuText" 
                                              Text="--" 
                                              FontSize="48" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource StarWhite}"/>
                                    <TextBlock Text="%" 
                                              FontSize="24" 
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,0,8"
                                              Foreground="{DynamicResource StarDim}"/>
                                </StackPanel>
                                <TextBlock x:Name="CpuPercentText" 
                                          Text="--% utilized" 
                                          FontSize="12"
                                          Foreground="{DynamicResource NebulaCyan}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- GPU Card -->
                        <Border Grid.Column="1" 
                               Background="#99000000" 
                               BorderBrush="#19FFFFFF"
                               BorderThickness="1"
                               CornerRadius="16"
                               Padding="24">
                            <StackPanel Spacing="12">
                                <TextBlock Text="GPU Usage" 
                                          FontSize="14" 
                                          FontWeight="Bold"
                                          Foreground="{DynamicResource StarDim}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="GpuText" 
                                              Text="--" 
                                              FontSize="48" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource StarWhite}"/>
                                    <TextBlock Text="%" 
                                              FontSize="24" 
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,0,8"
                                              Foreground="{DynamicResource StarDim}"/>
                                </StackPanel>
                                <TextBlock x:Name="GpuPercentText" 
                                          Text="--% utilized" 
                                          FontSize="12"
                                          Foreground="{DynamicResource NebulaCyan}"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Memory Card -->
                        <Border Grid.Column="2" 
                               Background="#99000000" 
                               BorderBrush="#19FFFFFF"
                               BorderThickness="1"
                               CornerRadius="16"
                               Padding="24">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Memory" 
                                          FontSize="14" 
                                          FontWeight="Bold"
                                          Foreground="{DynamicResource StarDim}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock x:Name="MemoryText" 
                                              Text="--" 
                                              FontSize="48" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource StarWhite}"/>
                                    <TextBlock Text="GB" 
                                              FontSize="24" 
                                              VerticalAlignment="Bottom"
                                              Margin="0,0,0,8"
                                              Foreground="{DynamicResource StarDim}"/>
                                </StackPanel>
                                <TextBlock x:Name="MemoryPercentText" 
                                          Text="--% utilized" 
                                          FontSize="12"
                                          Foreground="{DynamicResource NebulaCyan}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Storage Section -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="STORAGE" 
                                  FontSize="24" 
                                  FontWeight="Bold"
                                  Foreground="{DynamicResource StarWhite}"/>
                        
                        <!-- Drives will be added dynamically -->
                        <ItemsControl x:Name="DrivesPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#99000000" 
                                            BorderBrush="#19FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="24"
                                            Margin="8"
                                            Width="250"
                                            Height="180">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="{Binding Name}" 
                                                      FontSize="18" 
                                                      FontWeight="Bold"
                                                      Foreground="{DynamicResource StarWhite}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding FreeGB}" 
                                                          FontSize="36" 
                                                          FontWeight="Bold"
                                                          Foreground="{DynamicResource StarWhite}"/>
                                                <TextBlock Text="GB" 
                                                          FontSize="18" 
                                                          VerticalAlignment="Bottom"
                                                          Margin="0,0,0,6"
                                                          Foreground="{DynamicResource StarDim}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TotalText}" 
                                                      FontSize="12"
                                                      Foreground="{DynamicResource StarDim}"/>
                                            <TextBlock Text="{Binding PercentUsed}" 
                                                      FontSize="14"
                                                      Foreground="{DynamicResource NebulaCyan}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <!-- COMPRESSION TAB -->
        <TabItem Header="🗜️ Compression">
            <ScrollViewer>
                <StackPanel Margin="40" Spacing="32">
                    
                    <!-- Header -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Transparent Compression" 
                                  FontSize="36" 
                                  FontWeight="Bold"
                                  Foreground="{DynamicResource StarWhite}"/>
                        <TextBlock Text="Compress files and programs using Windows Compact"
                                  FontSize="14"
                                  Foreground="{DynamicResource StarDim}"/>
                    </StackPanel>
                    
                    <!-- Compression UI -->
                    <Border Background="#99000000" 
                            BorderBrush="#19FFFFFF"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        
                        <StackPanel Spacing="16">
                            <!-- Mode Selection -->
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <RadioButton x:Name="FileModeRadio" 
                                            Content="Files/Folders" 
                                            IsChecked="True"
                                            Foreground="{DynamicResource StarWhite}"/>
                                <RadioButton x:Name="ProgramModeRadio" 
                                            Content="Programs/Games"
                                            Foreground="{DynamicResource StarWhite}"/>
                            </StackPanel>
                            
                            <!-- File Mode Controls -->
                            <StackPanel x:Name="FileModePanel" Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button x:Name="SelectFolderButton" 
                                           Content="📁 Select Folder..." 
                                           Padding="12,8"
                                           Background="#33FFFFFF"
                                           Foreground="{DynamicResource StarWhite}"/>
                                    <ComboBox x:Name="AlgorithmComboBox" 
                                             Width="180"
                                             SelectedIndex="3"
                                             Foreground="{DynamicResource StarWhite}">
                                        <ComboBoxItem>XPRESS4K (Fast)</ComboBoxItem>
                                        <ComboBoxItem>XPRESS8K (Balanced)</ComboBoxItem>
                                        <ComboBoxItem>XPRESS16K (Better)</ComboBoxItem>
                                        <ComboBoxItem>LZX (Best)</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                
                                <TextBlock x:Name="SelectedPathText"
                                          Text="No folder selected"
                                          FontSize="12"
                                          Foreground="{DynamicResource StarDim}"/>
                            </StackPanel>
                            
                            <!-- Program Mode Controls -->
                            <StackPanel x:Name="ProgramModePanel" IsVisible="False" Spacing="12">
                                <Button x:Name="ScanProgramsButton" 
                                       Content="🔍 Scan for Programs/Games" 
                                       Padding="12,8"
                                       Background="#33FFFFFF"
                                       Foreground="{DynamicResource StarWhite}"/>
                                       
                                <!-- Program Filter Tabs (Folder Style) -->
                                <Border Background="#0DFFFFFF" 
                                       CornerRadius="8" 
                                       Padding="8,8,8,2"
                                       Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border x:Name="AllProgramsTab"
                                               Background="#336699FF"
                                               CornerRadius="6,6,0,0"
                                               Padding="16,8,16,8"
                                               Cursor="Hand">
                                            <TextBlock Text="📁 All Programs"
                                                      Foreground="{DynamicResource StarWhite}"
                                                      FontSize="13"
                                                      FontWeight="SemiBold"/>
                                        </Border>
                                        
                                        <Border x:Name="CompressedTab"
                                               Background="#19FFFFFF"
                                               CornerRadius="6,6,0,0"
                                               Padding="16,8,16,8"
                                               Cursor="Hand">
                                            <TextBlock Text="🗜️ Compressed"
                                                      Foreground="{DynamicResource StarDim}"
                                                      FontSize="13"/>
                                        </Border>
                                        
                                        <Border x:Name="UncompressedTab"
                                               Background="#19FFFFFF"
                                               CornerRadius="6,6,0,0"
                                               Padding="16,8,16,8"
                                               Cursor="Hand">
                                            <TextBlock Text="📦 Uncompressed"
                                                      Foreground="{DynamicResource StarDim}"
                                                      FontSize="13"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                       
                                <ListBox x:Name="ProgramListBox"
                                        Height="200"
                                        Background="#19FFFFFF"
                                        Foreground="{DynamicResource StarWhite}"/>
                            </StackPanel>
                            
                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="EstimateButton" 
                                       Content="📊 Estimate Space" 
                                       Padding="16,10"
                                       Background="#336699FF"
                                       Foreground="{DynamicResource StarWhite}"/>
                                <Button x:Name="CompressButton" 
                                       Content="🗜️ Compress" 
                                       Padding="16,10"
                                       Background="{DynamicResource PurpleGradient}"
                                       Foreground="{DynamicResource StarWhite}"/>
                                <Button x:Name="DecompressButton" 
                                       Content="📦 Decompress" 
                                       Padding="16,10"
                                       Background="#33FFFFFF"
                                       Foreground="{DynamicResource StarWhite}"/>
                            </StackPanel>
                            
                            <!-- Progress Bar -->
                            <StackPanel Spacing="8" Margin="0,10,0,0">
                                <ProgressBar x:Name="ProgressBar"
                                           Height="20"
                                           Minimum="0"
                                           Maximum="100"
                                           Value="0"
                                           Background="#19FFFFFF"
                                           Foreground="{DynamicResource PurpleGradient}"/>
                                <TextBlock x:Name="ProgressText"
                                          Text="Ready"
                                          FontSize="12"
                                          Foreground="{DynamicResource StarDim}"/>
                            </StackPanel>
                            
                            <!-- Analysis Results -->
                            <Border x:Name="AnalysisResults"
                                   IsVisible="False"
                                   Background="#19FFFFFF"
                                   BorderBrush="{DynamicResource PurpleGradient}"
                                   BorderThickness="2"
                                   CornerRadius="8"
                                   Padding="15"
                                   Margin="0,10,0,0">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="📊 Compression Analysis"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource StarWhite}"/>
                                    <TextBlock x:Name="AnalysisSummary"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource StarWhite}"
                                              TextWrapping="Wrap"/>
                                    <TextBlock x:Name="AnalysisDetails"
                                              FontSize="12"
                                              Foreground="{DynamicResource StarDim}"
                                              TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Status -->
                            <StackPanel Spacing="8" Margin="0,10,0,0">
                                <TextBlock x:Name="StatusText"
                                          Text="Ready"
                                          FontSize="14"
                                          Foreground="{DynamicResource StarWhite}"/>
                                <ProgressBar x:Name="CompressionProgress"
                                            Height="8"
                                            Maximum="100"
                                            Value="0"
                                            Background="#19FFFFFF"
                                            Foreground="{DynamicResource PurpleGradient}"/>
                                <TextBlock x:Name="ResultsText"
                                          FontSize="12"
                                          Foreground="{DynamicResource NebulaCyan}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </ScrollViewer>
        </TabItem>
        
        <!-- PLACEHOLDER TABS -->
        <TabItem Header="💾 RAM Optimizer" IsEnabled="False"/>
        <TabItem Header="⚡ Power Profiles" IsEnabled="False"/>
        <TabItem Header="🌐 Network" IsEnabled="False"/>
        <TabItem Header="⚙️ Settings" IsEnabled="False"/>
        
    </TabControl>

</Window>
