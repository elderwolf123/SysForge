<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="50"
             x:Class="RamOptimizerNova.Controls.NavigationItem"
             x:DataType="RamOptimizerNova.Controls.NavigationItem">
    
    <UserControl.Styles>
        <Style Selector="NavigationItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ContentPresenter Content="{TemplateBinding Icon}"
                                              Width="20"
                                              Height="20"
                                              VerticalAlignment="Center"/>
                            <ContentPresenter Content="{TemplateBinding Title}"
                                              VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        
        <Style Selector="NavigationItem:pointerover">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#475569"/>
        </Style>
        
        <Style Selector="NavigationItem:pressed">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
        </Style>
        
        <Style Selector="NavigationItem:selected">
            <Setter Property="Background" Value="#6366F120"/>
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
        </Style>
        
        <Style Selector="NavigationItem:selected:pointerover">
            <Setter Property="Background" Value="#6366F140"/>
            <Setter Property="BorderBrush" Value="#8B5CF6"/>
        </Style>
        
        <Style Selector="NavigationItem:disabled">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Cursor" Value="Default"/>
        </Style>
    </UserControl.Styles>
    
    <StackPanel Orientation="Horizontal" Spacing="12">
        <ContentPresenter Content="{Binding Icon}"
                          Width="20"
                          Height="20"
                          VerticalAlignment="Center"/>
        <ContentPresenter Content="{Binding Title}"
                          VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>