    <TrimmerWarnOnUnreferencedTypeParameterVarianceAttributes>true</TrimmerWarnOnUnreferencedTypeParameterVarianceAttributes>
    <TrimmerWarnOnUnreferencedTypeParameterConstraintAttributes>true</TrimmerWarnOnUnreferencedTypeParameterConstraintAttributes>
    <TrimmerWarnOnUnreferencedTypeParameterConstraintTypes>true</TrimmerWarnOnUnreferencedTypeParameterConstraintTypes>
