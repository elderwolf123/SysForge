<!-- Nova UI Dark Theme - Enhanced dark theme with space aesthetics -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Dark Theme Colors -->
    <Color x:Key="BackgroundColor">#030712</Color>
    <Color x:Key="SurfaceColor">#111827</Color>
    <Color x:Key="SurfaceColorHover">#1F2937</Color>
    <Color x:Key="SurfaceColorPressed">#374151</Color>
    <Color x:Key="CardColor">#111827</Color>
    <Color x:Key="CardColorHover">#1F2937</Color>
    <Color x:Key="CardColorPressed">#374151</Color>
    
    <!-- Dark Theme Text Colors -->
    <Color x:Key="TextColorPrimary">#F9FAFB</Color>
    <Color x:Key="TextColorSecondary">#D1D5DB</Color>
    <Color x:Key="TextColorTertiary">#9CA3AF</Color>
    <Color x:Key="TextColorDisabled">#6B7280</Color>
    
    <!-- Dark Theme Border Colors -->
    <Color x:Key="BorderColor">#374151</Color>
    <Color x:Key="BorderColorHover">#4B5563</Color>
    <Color x:Key="BorderColorPressed">#6B7280</Color>
    
    <!-- Dark Theme Shadow Colors -->
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="ShadowColorPrimary">#00000040</Color>
    <Color x:Key="ShadowColorSecondary">#00000060</Color>
    <Color x:Key="ShadowColorTertiary">#00000080</Color>
    
    <!-- Dark Theme Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceBrushHover" Color="{StaticResource SurfaceColorHover}"/>
    <SolidColorBrush x:Key="SurfaceBrushPressed" Color="{StaticResource SurfaceColorPressed}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="CardBrushHover" Color="{StaticResource CardColorHover}"/>
    <SolidColorBrush x:Key="CardBrushPressed" Color="{StaticResource CardColorPressed}"/>
    
    <SolidColorBrush x:Key="TextBrushPrimary" Color="{StaticResource TextColorPrimary}"/>
    <SolidColorBrush x:Key="TextBrushSecondary" Color="{StaticResource TextColorSecondary}"/>
    <SolidColorBrush x:Key="TextBrushTertiary" Color="{StaticResource TextColorTertiary}"/>
    <SolidColorBrush x:Key="TextBrushDisabled" Color="{StaticResource TextColorDisabled}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderBrushHover" Color="{StaticResource BorderColorHover}"/>
    <SolidColorBrush x:Key="BorderBrushPressed" Color="{StaticResource BorderColorPressed}"/>
    
    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="ShadowBrushPrimary" Color="{StaticResource ShadowColorPrimary}"/>
    <SolidColorBrush x:Key="ShadowBrushSecondary" Color="{StaticResource ShadowColorSecondary}"/>
    <SolidColorBrush x:Key="ShadowBrushTertiary" Color="{StaticResource ShadowColorTertiary}"/>
    
    <!-- Dark Theme Global Styles -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
    </Style>
    
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="1.5"/>
    </Style>
    
    <Style Selector="TextBlock.header">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="700"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
    </Style>
    
    <Style Selector="TextBlock.title">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
    </Style>
    
    <Style Selector="TextBlock.subtitle">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="500"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushSecondary}"/>
    </Style>
    
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="400"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushTertiary}"/>
    </Style>
    
    <Style Selector="TextBlock.success">
        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
    </Style>
    
    <Style Selector="TextBlock.warning">
        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
    </Style>
    
    <Style Selector="TextBlock.error">
        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
    </Style>
    
    <Style Selector="TextBlock.info">
        <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
    </Style>
    
    <!-- Dark Theme Button Styles -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Cursor="{TemplateBinding Cursor}"
                        BoxShadow="0 4 16 0 #00000040">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BoxShadow" Value="0 6 20 0 #00000060"/>
    </Style>
    
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="BoxShadow" Value="0 2 12 0 #00000080"/>
    </Style>
    
    <Style Selector="Button:disabled">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushDisabled}"/>
        <Setter Property="Cursor" Value="Default"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>
    
    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="Button.secondary:pressed">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrushDark}"/>
    </Style>
    
    <Style Selector="Button.danger:pointerover">
        <Setter Property="Background" Value="{StaticResource ErrorBrushDark}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
    </Style>
    
    <Style Selector="Button.danger:pressed">
        <Setter Property="Background" Value="#DC2626"/>
        <Setter Property="BorderBrush" Value="#B91C1C"/>
    </Style>
    
    <Style Selector="Button.success">
        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrushDark}"/>
    </Style>
    
    <Style Selector="Button.success:pointerover">
        <Setter Property="Background" Value="{StaticResource SuccessBrushDark}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
    </Style>
    
    <Style Selector="Button.success:pressed">
        <Setter Property="Background" Value="#059669"/>
        <Setter Property="BorderBrush" Value="#047857"/>
    </Style>
    
    <!-- Dark Theme Input Styles -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,16"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource PrimaryBrushLight}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ScrollViewer Margin="{TemplateBinding Padding}"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"/>
                    </ScrollViewer>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="TextBox:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BoxShadow" Value="0 0 0 2 #6366F140"/>
    </Style>
    
    <Style Selector="TextBox:disabled">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushDisabled}"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,16"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"/>
                        <Path Data="M0,0 L1,0 L0.5,1 Z"
                              Fill="{StaticResource TextBrushSecondary}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              Width="8"
                              Height="8"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="ComboBox:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="ComboBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BoxShadow" Value="0 0 0 2 #6366F140"/>
    </Style>
    
    <Style Selector="ComboBox:disabled">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushDisabled}"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    
    <Style Selector="CheckBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Width="20"
                            Height="20">
                        <Path Data="M0,0 L1,0 L0.5,1 Z"
                              Fill="{StaticResource PrimaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="4,4,4,4"
                              Visibility="{TemplateBinding IsChecked, Converter={x:Static ObjectConverters.VisibilityConverter}}"
                              Width="8"
                              Height="8"/>
                    </Border>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"/>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="CheckBox:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="CheckBox:checked">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
    </Style>
    
    <Style Selector="CheckBox:disabled">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushDisabled}"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    
    <Style Selector="Slider">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushPrimary}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid>
                            <Rectangle Fill="{StaticResource PrimaryBrush}"
                                       Height="4"
                                       VerticalAlignment="Center"
                                       Margin="4,0,4,0"/>
                            <Ellipse Fill="{StaticResource PrimaryBrush}"
                                     Width="16"
                                     Height="16"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Left"
                                     Margin="4,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="Slider:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="Slider:focus">
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BoxShadow" Value="0 0 0 2 #6366F140"/>
    </Style>
    
    <Style Selector="Slider:disabled">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushDisabled}"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    
    <!-- Dark Theme Custom Control Styles -->
    <Style Selector="GlassCard">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BoxShadow" Value="0 4 24 0 #00000040"/>
    </Style>
    
    <Style Selector="GlassCard:pointerover">
        <Setter Property="Background" Value="{StaticResource CardBrushHover}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="GlassCard:pressed">
        <Setter Property="Background" Value="{StaticResource CardBrushPressed}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushPressed}"/>
    </Style>
    
    <Style Selector="ModernButton">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="44"/>
    </Style>
    
    <Style Selector="ModernButton:pointerover">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BoxShadow" Value="0 4 16 0 #6366F140"/>
    </Style>
    
    <Style Selector="ModernButton:pressed">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="BoxShadow" Value="0 2 12 0 #6366F160"/>
    </Style>
    
    <Style Selector="ModernButton:disabled">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrushDisabled}"/>
        <Setter Property="Cursor" Value="Default"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>
    
    <Style Selector="ModernButton.secondary">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>
    
    <Style Selector="ModernButton.secondary:pointerover">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="ModernButton.secondary:pressed">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushDark}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="ModernButton.danger">
        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrushDark}"/>
    </Style>
    
    <Style Selector="ModernButton.danger:pointerover">
        <Setter Property="Background" Value="{StaticResource ErrorBrushDark}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
    </Style>
    
    <Style Selector="ModernButton.danger:pressed">
        <Setter Property="Background" Value="#DC2626"/>
        <Setter Property="BorderBrush" Value="#B91C1C"/>
    </Style>
    
    <Style Selector="ModernButton.success">
        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrushDark}"/>
    </Style>
    
    <Style Selector="ModernButton.success:pointerover">
        <Setter Property="Background" Value="{StaticResource SuccessBrushDark}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
    </Style>
    
    <Style Selector="ModernButton.success:pressed">
        <Setter Property="Background" Value="#059669"/>
        <Setter Property="BorderBrush" Value="#047857"/>
    </Style>
    
    <Style Selector="NavigationItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="NavigationItem:pointerover">
        <Setter Property="Background" Value="{StaticResource SurfaceBrushHover}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="NavigationItem:pressed">
        <Setter Property="Background" Value="{StaticResource SurfaceBrushPressed}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushPressed}"/>
    </Style>
    
    <Style Selector="NavigationItem:selected">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>
    
    <Style Selector="NavigationItem:selected:pointerover">
        <Setter Property="Background" Value="{StaticResource PrimaryBrushLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
    </Style>
    
    <Style Selector="NavigationItem:disabled">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="Default"/>
    </Style>
    
    <Style Selector="MetricsCard">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BoxShadow" Value="0 4 24 0 #00000040"/>
    </Style>
    
    <Style Selector="MetricsCard:pointerover">
        <Setter Property="Background" Value="{StaticResource CardBrushHover}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
    </Style>
    
    <Style Selector="MetricsCard:pressed">
        <Setter Property="Background" Value="{StaticResource CardBrushPressed}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushPressed}"/>
    </Style>
    
    <Style Selector="ProgressRing">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="StrokeThickness" Value="3"/>
        <Setter Property="StrokeDashArray" Value="126"/>
        <Setter Property="StrokeDashOffset" Value="0"/>
    </Style>
    
    <Style Selector="ProgressRing.active">
        <Setter Property="IsVisible" Value="True"/>
    </Style>
    
    <Style Selector="ProgressRing.inactive">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    
    <Style Selector="NavigationFrame">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Padding" Value="24"/>
    </Style>
    
    <!-- Dark Theme Animation Styles -->
    <Style Selector="ContentPresenter#transitioning">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="TranslateTransform" Value="0,0"/>
    </Style>
    
    <Style Selector="ContentPresenter">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="TranslateTransform" Value="0,20"/>
    </Style>
    
    <!-- Dark Theme Transition Animation -->
    <Style Selector="ContentPresenter">
        <Style.Animations>
            <Animation Duration="0:0:0.3"
                       Easing="CubicOut"
                       FillMode="Both">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="TranslateTransform.Y" Value="20"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="TranslateTransform.Y" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
</Styles>