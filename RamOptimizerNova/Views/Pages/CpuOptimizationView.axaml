<UserControl x:Class="RamOptimizerNova.Views.Pages.CpuOptimizationView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:RamOptimizerNova.Views.Pages"
             xmlns:controls="clr-namespace:RamOptimizerNova.Controls"
             xmlns:vm="clr-namespace:RamOptimizerNova.ViewModels.Pages"
             mc:Ignorable="d" 
             d:DesignWidth="1200" d:DesignHeight="800"
             x:DataType="vm:CpuOptimizationViewModel">
    
    <UserControl.Resources>
        <!-- CPU Usage Color Converter -->
        <local:CpuUsageColorConverter x:Key="CpuUsageColorConverter"/>
        
        <!-- CPU Usage Progress Bar Style -->
        <Style x:Key="CpuUsageProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#757575"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Glass Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF20"/>
            <Setter Property="BorderBrush" Value="#FFFFFF40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        
        <!-- Process Item Style -->
        <Style x:Key="ProcessItem" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF10"/>
            <Setter Property="BorderBrush" Value="#FFFFFF30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="CPU Optimization" 
                           FontSize="28" 
                           FontWeight="Light"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Optimize CPU performance and manage process priorities"
                           FontSize="14" 
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Opacity="0.8"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource ModernButton}"/>
                <Button Content="Auto Optimize" 
                        Command="{Binding AutoOptimizeCommand}"
                        Style="{StaticResource ModernButton}"/>
                <Button Content="Reset All" 
                        Command="{Binding ResetAllCommand}"
                        Style="{StaticResource ModernButton}"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Margin="20,0,20,20">
            <StackPanel Spacing="20">
                <!-- CPU Overview Section -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="CPU Overview" 
                                   FontSize="18" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <Grid ColumnDefinitions="1*,1*,1*" RowDefinitions="Auto,Auto">
                            <!-- CPU Usage -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                                <TextBlock Text="CPU Usage" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ProgressBar Value="{Binding CurrentCpuUsage}" 
                                             Maximum="100"
                                             Style="{StaticResource CpuUsageProgressBar}"/>
                                <TextBlock Text="{Binding CurrentCpuUsage, StringFormat='{}{0:F1}%'}"
                                           FontSize="24" 
                                           FontWeight="Light"
                                           Foreground="{Binding CurrentCpuUsage, Converter={StaticResource CpuUsageColorConverter}}"/>
                            </StackPanel>
                            
                            <!-- Temperature -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                                <TextBlock Text="Temperature" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ProgressBar Value="{Binding CurrentTemperature}" 
                                             Maximum="100"
                                             Style="{StaticResource CpuUsageProgressBar}"/>
                                <TextBlock Text="{Binding CurrentTemperature, StringFormat='{}{0:F1}°C'}"
                                           FontSize="24" 
                                           FontWeight="Light"
                                           Foreground="{Binding CurrentTemperature, Converter={StaticResource CpuUsageColorConverter}}"/>
                            </StackPanel>
                            
                            <!-- Core Count -->
                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="8">
                                <TextBlock Text="Active Cores" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding ActiveCores, StringFormat='{}{0} / {1}'}"
                                           FontSize="24" 
                                           FontWeight="Light"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="Total Cores"
                                           FontSize="12" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                            
                            <!-- CPU Info -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Spacing="4">
                                <TextBlock Text="{Binding CpuModel}"
                                           FontSize="12" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CpuFrequency, StringFormat='Frequency: {0} GHz'}"
                                           FontSize="12" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Optimization Controls -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Optimization Controls" 
                                   FontSize="18" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <Grid ColumnDefinitions="1*,1*,1*" RowDefinitions="Auto,Auto">
                            <!-- Power Plan -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
                                <TextBlock Text="Power Plan" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox ItemsSource="{Binding PowerPlans}"
                                          SelectedItem="{Binding SelectedPowerPlan}"
                                          Margin="0,4"/>
                            </StackPanel>
                            
                            <!-- CPU Priority -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
                                <TextBlock Text="Default Priority" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox ItemsSource="{Binding PriorityLevels}"
                                          SelectedItem="{Binding SelectedPriority}"
                                          Margin="0,4"/>
                            </StackPanel>
                            
                            <!-- Core Affinity -->
                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="8">
                                <TextBlock Text="Core Affinity" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox ItemsSource="{Binding CoreAffinityOptions}"
                                          SelectedItem="{Binding SelectedCoreAffinity}"
                                          Margin="0,4"/>
                            </StackPanel>
                            
                            <!-- Apply Button -->
                            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                    Content="Apply Settings"
                                    Command="{Binding ApplySettingsCommand}"
                                    Style="{StaticResource ModernButton}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Process Management -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Process Management" 
                                       FontSize="18" 
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        Spacing="8">
                                <Button Content="Add Process" 
                                        Command="{Binding AddProcessCommand}"
                                        Style="{StaticResource ModernButton}"/>
                                <Button Content="Remove Selected" 
                                        Command="{Binding RemoveSelectedCommand}"
                                        Style="{StaticResource ModernButton}"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Process List -->
                        <DataGrid ItemsSource="{Binding ProcessItems}"
                                  SelectedItem="{Binding SelectedProcess}"
                                  CanUserResizeColumns="True"
                                  AutoGenerateColumns="False"
                                  Margin="0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" 
                                                    Binding="{Binding Name}" 
                                                    Width="2*"/>
                                <DataGridTextColumn Header="PID" 
                                                    Binding="{Binding Id}" 
                                                    Width="80"/>
                                <DataGridTextColumn Header="CPU %" 
                                                    Binding="{Binding CpuUsage}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Memory" 
                                                    Binding="{Binding MemoryUsage}" 
                                                    Width="100"/>
                                <DataGridTextColumn Header="Priority" 
                                                    Binding="{Binding Priority}" 
                                                    Width="120"/>
                                <DataGridTextColumn Header="Status" 
                                                    Binding="{Binding Status}" 
                                                    Width="100"/>
                                <DataGridTemplateColumn Header="Actions" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Button Content="Boost" 
                                                        Command="{Binding DataContext.BoostProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ModernButton}"
                                                        Width="50"/>
                                                <Button Content="Limit" 
                                                        Command="{Binding DataContext.LimitProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ModernButton}"
                                                        Width="50"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                
                <!-- Optimization Presets -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Optimization Presets" 
                                   FontSize="18" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <WrapPanel Spacing="12">
                            <Button Content="Gaming Mode" 
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="Gaming"
                                    Style="{StaticResource ModernButton}"/>
                            <Button Content="Productivity Mode" 
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="Productivity"
                                    Style="{StaticResource ModernButton}"/>
                            <Button Content="Power Saver" 
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="PowerSaver"
                                    Style="{StaticResource ModernButton}"/>
                            <Button Content="High Performance" 
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="HighPerformance"
                                    Style="{StaticResource ModernButton}"/>
                            <Button Content="Balanced" 
                                    Command="{Binding ApplyPresetCommand}"
                                    CommandParameter="Balanced"
                                    Style="{StaticResource ModernButton}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                
                <!-- Performance History -->
                <Border Style="{StaticResource GlassCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Performance History" 
                                   FontSize="18" 
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*">
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="CPU Usage History" 
                                       FontSize="14" 
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                       Text="Temperature History" 
                                       FontSize="14" 
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            
                            <ContentControl Grid.Row="1" Grid.Column="0" 
                                            Content="{Binding CpuUsageChart}"/>
                            <ContentControl Grid.Row="1" Grid.Column="1" 
                                            Content="{Binding TemperatureChart}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Status Bar -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       Text="{Binding StatusMessage}"
                       FontSize="12" 
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        Spacing="16">
                <TextBlock Text="Last Updated: " 
                           FontSize="12" 
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="{Binding LastUpdateTime, StringFormat='{0:HH:mm:ss}'}" 
                           FontSize="12" 
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>