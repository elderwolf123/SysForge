<Window x:Class="RamOptimizerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RAM Optimizer Pro" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E">
    
    <Window.Resources>
        <!-- Modern Color Palette -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF0078D4"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#FF00A4EF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF00CC6A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FFE81123"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFFFB900"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FF2D2D30"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFF1F1F1"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="#FFB0B0B0"/>
        
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- Success Button Style -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Modern ListBox Style -->
        <Style x:Key="ModernListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Modern ProgressBar Style -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="RAM Optimizer Pro" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Advanced System Optimization Suite" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Ready" FontSize="14" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="0" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{StaticResource SurfaceBrush}" 
                                        BorderThickness="0" Padding="20,12" Margin="0,0,2,0">
                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#FF3F3F46"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </TabControl.Resources>

            <!-- Process Management Tab -->
            <TabItem Header="🎯 Process Management">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Target Processes Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Target Processes" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox x:Name="ProcessNameTextBox" Style="{StaticResource ModernTextBox}" 
                                            Grid.Column="0" Margin="0,0,10,0"
                                            Text="notepad.exe"/>
                                    
                                    <Button Grid.Column="1" Content="Add Process" Style="{StaticResource SuccessButton}" 
                                           Click="AddTargetProcess_Click" Width="120"/>
                                </Grid>

                                <ListBox x:Name="TargetProcessesListBox" Style="{StaticResource ModernListBox}" 
                                        Height="150" Margin="0,16,0,0"/>

                                <Button Content="Remove Selected" Style="{StaticResource DangerButton}" 
                                       Click="RemoveTargetProcess_Click" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Termination Levels Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Memory Termination Levels" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Aggressively free memory by terminating processes" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16"/>
                                
                                <UniformGrid Columns="4" Rows="2">
                                    <Button Content="Level 1 (Mild)" Style="{StaticResource ModernButton}" Margin="0,0,8,8" Tag="1" Click="TerminateLevel_Click"/>
                                    <Button Content="Level 2" Style="{StaticResource ModernButton}" Margin="0,0,8,8" Tag="2" Click="TerminateLevel_Click"/>
                                    <Button Content="Level 3" Style="{StaticResource ModernButton}" Margin="0,0,8,8" Tag="3" Click="TerminateLevel_Click"/>
                                    <Button Content="Level 4" Style="{StaticResource ModernButton}" Margin="0,0,0,8" Tag="4" Click="TerminateLevel_Click"/>
                                    <Button Content="Level 5" Style="{StaticResource DangerButton}" Margin="0,0,8,0" Tag="5" Click="TerminateLevel_Click"/>
                                    <Button Content="Level 6" Style="{StaticResource DangerButton}" Margin="0,0,8,0" Tag="6" Click="TerminateLevel_Click"/>
                                    <Button Content="Level 7 (Extreme)" Style="{StaticResource DangerButton}" Margin="0,0,8,0" Tag="7" Click="TerminateLevel_Click"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- CPU Optimization Tab -->
            <TabItem Header="⚡ CPU Optimization">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="CPU Optimization" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Optimize CPU allocation and performance for target processes" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <Button Content="🚀 Optimize CPU for Target Processes" Style="{StaticResource SuccessButton}" 
                                       Click="OptimizeCpu_Click" Padding="20,12" FontSize="16" Margin="0,0,0,20"/>

                                <TextBlock Text="Features:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                                <TextBlock Text="• Allocate performance cores to target processes" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Prevent thermal throttling" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Enable advanced CPU cooling" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Dynamic priority adjustment" FontSize="13" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- GPU Optimization Tab -->
            <TabItem Header="🎮 GPU Optimization">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="GPU Optimization" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Maximize GPU performance for gaming and graphics applications" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <Button Content="🎮 Optimize GPU for Target Processes" Style="{StaticResource SuccessButton}" 
                                       Click="OptimizeGpu_Click" Padding="20,12" FontSize="16" Margin="0,0,0,20"/>

                                <TextBlock Text="Features:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                                <TextBlock Text="• Prioritize GPU processes" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Control hardware acceleration" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Optimize GPU scheduler" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Aggressive GPU resource allocation" FontSize="13" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- File Compression Tab -->
            <TabItem Header="📦 File Compression">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Hybrid File Compression" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Advanced compression using LZMA, Brotli, Deflate, and Near-Lossless algorithms" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox x:Name="CompressionPathTextBox" Style="{StaticResource ModernTextBox}" 
                                            Grid.Column="0" Margin="0,0,10,0"
                                            Text="C:\"/>
                                    
                                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource ModernButton}" 
                                           Click="BrowseCompressionPath_Click" Width="100"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="📦 Compress" Style="{StaticResource SuccessButton}" 
                                           Click="CompressPath_Click" Margin="0,0,10,0" Padding="20,10"/>
                                    <Button Content="🚀 Start Background Compression" Style="{StaticResource ModernButton}" 
                                           Click="StartBackgroundCompression_Click" Padding="20,10"/>
                                </StackPanel>

                                <TextBlock Text="Compression Algorithms:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,20,0,10"/>
                                <TextBlock Text="• LZMA - Maximum compression for executables" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Brotli - Optimal for text and documents" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Deflate - Fast compression for archives" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="• Near-Lossless - Smart image compression" FontSize="13" Foreground="{StaticResource SubtextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Performance Control Tab -->
            <TabItem Header="⚙️ Performance Control">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Performance Mode Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Performance Mode" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Control ASUS performance profiles and Windows power plans" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <TextBlock Text="Current Mode:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="CurrentPerfModeText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                                
                                <UniformGrid Columns="3" Rows="1">
                                    <Button Content="🔇 Silent" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="1" Click="SetPerformanceMode_Click"/>
                                    <Button Content="⚖️ Balanced" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="0" Click="SetPerformanceMode_Click"/>
                                    <Button Content="🚀 Turbo" Style="{StaticResource SuccessButton}" Margin="0,0,0,0" Tag="3" Click="SetPerformanceMode_Click"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- GPU Mode Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="GPU Mode" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Switch between iGPU and dGPU configurations (requires restart)" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <TextBlock Text="Current Mode:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="CurrentGpuModeText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                                
                                <UniformGrid Columns="3" Rows="1">
                                    <Button Content="🌱 Eco" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="0" Click="SetGpuMode_Click"/>
                                    <Button Content="⚡ Standard" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="1" Click="SetGpuMode_Click"/>
                                    <Button Content="🔥 Ultimate" Style="{StaticResource SuccessButton}" Margin="0,0,0,0" Tag="2" Click="SetGpuMode_Click"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Hardware Monitoring Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Hardware Monitoring" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                                
                                <!-- CPU Temperature -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="CPU Temperature" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="CpuTempText" Grid.Column="1" Text="--°C" FontSize="16" 
                                              Foreground="{StaticResource AccentBrush}" TextAlignment="Right"/>
                                </Grid>

                                <!-- CPU Fan Speed -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="CPU Fan Speed" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="CpuFanText" Grid.Column="1" Text="--%"  FontSize="16" 
                                              Foreground="{StaticResource AccentBrush}" TextAlignment="Right"/>
                                </Grid>

                                <!-- Battery Charge Limit -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="Battery Charge Limit" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BatteryLimitText" Grid.Column="1" Text="--%"  FontSize="16" 
                                              Foreground="{StaticResource AccentBrush}" TextAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <!-- Battery Limit Control Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Battery Charge Limit" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Set maximum battery charge level to preserve battery health" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <TextBlock Text="Current Limit:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="CurrentBatteryLimitText" Text="100%" FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                                
                                <!-- Slider -->
                                <TextBlock Text="Set New Limit:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Slider x:Name="BatteryLimitSlider" Minimum="60" Maximum="100" Value="80" 
                                            TickFrequency="5" IsSnapToTickEnabled="True" 
                                            Margin="0,0,10,0" VerticalAlignment="Center"
                                            ValueChanged="BatteryLimitSlider_ValueChanged"/>
                                    <TextBlock x:Name="BatteryLimitSliderText" Grid.Column="1" Text="80%" FontSize="16" 
                                               Foreground="{StaticResource AccentBrush}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Preset Buttons -->
                                <TextBlock Text="Quick Presets:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                                    <Button Content="60% (Storage)" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="60" Click="SetBatteryLimitPreset_Click"/>
                                    <Button Content="80% (Daily)" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="80" Click="SetBatteryLimitPreset_Click"/>
                                    <Button Content="100% (Full)" Style="{StaticResource SuccessButton}" Margin="0,0,0,0" Tag="100" Click="SetBatteryLimitPreset_Click"/>
                                </UniformGrid>
                                
                                <!-- Apply Button -->
                                <Button Content="Apply Battery Limit" Style="{StaticResource SuccessButton}" Click="ApplyBatteryLimit_Click"/>
                                
                                <TextBlock Text="⚠️ Changes require app to run on startup for persistence" FontSize="12" 
                                           Foreground="{StaticResource WarningBrush}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- CPU Core Control Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="CPU Core Control" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <TextBlock Text="Enable/Disable P-cores and E-cores (Requires Restart)" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                                
                                <!-- CPU Info -->
                                <TextBlock Text="Detected CPU:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="CpuInfoText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="Max Cores:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="MaxCoresText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="Current Configuration:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="CurrentCoresText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                                
                                <!-- P-Core Slider -->
                                <TextBlock Text="P-Cores (Performance):" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="PCoreSlider" Minimum="1" Maximum="8" Value="4" 
                                            TickFrequency="1" IsSnapToTickEnabled="True" 
                                            Margin="0,0,10,0" VerticalAlignment="Center"
                                            ValueChanged="PCoreSlider_ValueChanged"/>
                                    <TextBlock x:Name="PCoreSliderText" Grid.Column="1" Text="4" FontSize="16" 
                                               Foreground="{StaticResource AccentBrush}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- E-Core Slider -->
                                <TextBlock Text="E-Cores (Efficiency):" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="ECoreSlider" Minimum="0" Maximum="16" Value="8" 
                                            TickFrequency="1" IsSnapToTickEnabled="True" 
                                            Margin="0,0,10,0" VerticalAlignment="Center"
                                            ValueChanged="ECoreSlider_ValueChanged"/>
                                    <TextBlock x:Name="ECoreSliderText" Grid.Column="1" Text="8" FontSize="16" 
                                               Foreground="{StaticResource AccentBrush}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Presets -->
                                <TextBlock Text="Quick Presets:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                                    <Button Content="All Cores" Style="{StaticResource SuccessButton}" Margin="0,0,8,0" Tag="all" Click="SetCorePreset_Click"/>
                                    <Button Content="P-Only" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="ponly" Click="SetCorePreset_Click"/>
                                    <Button Content="Balanced" Style="{StaticResource ModernButton}" Margin="0,0,0,0" Tag="balanced" Click="SetCorePreset_Click"/>
                                </UniformGrid>
                                
                                <!-- Apply Button -->
                                <Button Content="Apply Core Configuration" Style="{StaticResource DangerButton}" Click="ApplyCoreConfig_Click"/>
                                <TextBlock Text="⚠️ RESTART REQUIRED for changes to take effect" FontSize="12" 
                                           Foreground="{StaticResource WarningBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Monitoring Tab -->
            <TabItem Header="📊 System Monitoring">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Performance Metrics Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Real-Time Performance" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                                
                                <!-- CPU Usage -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="CPU" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="CpuUsageBar" Grid.Column="1" Style="{StaticResource ModernProgressBar}" 
                                                Maximum="100" Value="0" Margin="10,0"/>
                                    <TextBlock x:Name="CpuUsageText" Grid.Column="2" Text="0%" FontSize="14" 
                                              Foreground="{StaticResource AccentBrush}" Width="60" TextAlignment="Right"/>
                                </Grid>

                                <!-- RAM Usage -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="RAM" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Style="{StaticResource ModernProgressBar}" 
                                                Maximum="100" Value="50" Margin="10,0"/>
                                    <TextBlock x:Name="RamUsageText" Grid.Column="2" Text="8192 MB Available" FontSize="14" 
                                              Foreground="{StaticResource AccentBrush}" Width="150" TextAlignment="Right"/>
                                </Grid>

                                <!-- Disk Usage -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Text="Disk" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="DiskUsageBar" Grid.Column="1" Style="{StaticResource ModernProgressBar}" 
                                                Maximum="100" Value="0" Margin="10,0"/>
                                    <TextBlock x:Name="DiskUsageText" Grid.Column="2" Text="0%" FontSize="14" 
                                              Foreground="{StaticResource AccentBrush}" Width="60" TextAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Activity Log Card -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Activity Log" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <Button Content="Clear" Style="{StaticResource ModernButton}" 
                                           Click="ClearLogs_Click" HorizontalAlignment="Right" Padding="12,6"/>
                                </Grid>
                                
                                <ListBox x:Name="LogListBox" Style="{StaticResource ModernListBox}" Height="300"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20,12">
            <TextBlock Text="© 2025 RAM Optimizer Pro - Advanced System Optimization" 
                      FontSize="12" Foreground="{StaticResource SubtextBrush}" 
                      HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
