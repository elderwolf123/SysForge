<UserControl x:Class="RamOptimizerUI.Views.ACPIMonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="850">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Page Title -->
            <TextBlock Text="🔬 ACPI Monitoring &amp; Validation" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <!-- Info Card -->
            <Border Style="{StaticResource Card}" Background="#1e2a3a" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="ℹ️ About ACPI Monitoring" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8">
                        This tool verifies that our ACPI device IDs match those used by official tools (G-Helper, Armory Crate).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextBrush}">
                        It captures ACPI transactions from official tools using Process Monitor and compares them with our implementation.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Quick Actions Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Quick Actions" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <UniformGrid Columns="4" Rows="1">
                        <Button x:Name="LoadCapturesButton" Content="📂 Load Captures" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="LoadCaptures_Click"/>
                        <Button x:Name="AddManualButton" Content="➕ Add Manual" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="AddManual_Click"/>
                        <Button x:Name="VerifyButton" Content="✅ Verify All" Style="{StaticResource SuccessButton}" Margin="0,0,8,0" Click="Verify_Click"/>
                        <Button x:Name="ClearButton" Content="🗑️ Clear All" Style="{StaticResource DangerButton}" Margin="0,0,0,0" Click="Clear_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Validation Results Card -->
            <Border Style="{StaticResource Card}" x:Name="ValidationCard" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Validation Results" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Total Captured" FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                            <TextBlock x:Name="TotalCapturedText" Text="0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Matches" FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                            <TextBlock x:Name="MatchesText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Mismatches" FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                            <TextBlock x:Name="MismatchesText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#f44336"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Status Message -->
                    <Border x:Name="ValidationStatusBorder" Background="#1e2a1e" BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="4" Padding="12" Margin="0,0,0,16">
                        <TextBlock x:Name="ValidationStatusText" Text="✅ All device IDs match!" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" TextWrapping="Wrap"/>
                    </Border>
                    
                    <!-- Match/Mismatch Details -->
                    <TextBlock Text="Details:" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <Border BorderBrush="{StaticResource SubtextBrush}" BorderThickness="1" CornerRadius="4" MaxHeight="200" Margin="0,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ValidationDetailsPanel" Background="Transparent">
                                <!-- Populated dynamically -->
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Captured Transactions Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Captured ACPI Transactions" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="TransactionCountText" Text="0 transactions" FontSize="13" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Transactions List -->
                    <Border BorderBrush="{StaticResource SubtextBrush}" BorderThickness="1" CornerRadius="4" MaxHeight="400">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <DataGrid x:Name="TransactionsDataGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="{StaticResource TextBrush}"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource SubtextBrush}"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#10FFFFFF">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="80"/>
                                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="120"/>
                                    <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceIdHex}" Width="100"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding ValueHex}" Width="100"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                            </DataGrid>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Device ID Reference Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="📋 Device ID Reference" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Performance Mode:" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="PerfModeDeviceIdText" Text="0x00120075" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="GPU Mode:" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="GpuModeDeviceIdText" Text="0x00090019" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="CPU Cores:" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="CoresDeviceIdText" Text="0x00110011" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Battery Limit:" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="BatteryLimitDeviceIdText" Text="0x00120056" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Fan Curve:" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FanCurveDeviceIdText" Text="0x00110024" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Turbo Mode:" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TurboModeDeviceIdText" Text="0x00120077" FontSize="14" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
