<UserControl x:Class="RamOptimizerUI.Views.CompressionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="850">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Page Title -->
            <TextBlock Text="🗜️ File Compression" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <!-- Compression Tier Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Compression Tier" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Choose the right tier for your use case" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Tier 1: Windows Compact -->
                        <Border Grid.Column="0" x:Name="Tier1Border" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2" CornerRadius="8" Padding="12" Margin="0,0,6,0" Cursor="Hand" MouseDown="Tier1_Click">
                            <StackPanel>
                                <TextBlock Text="🟢 Tier 1" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Windows Compact" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="• ~55% compression" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Instant access" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Safe for all games" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Anti-cheat compatible" FontSize="10" Foreground="#4CAF50" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Tier 2: Virtual FS -->
                        <Border Grid.Column="1" x:Name="Tier2Border" BorderBrush="{StaticResource SubtextBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6,0,6,0" Cursor="Hand" MouseDown="Tier2_Click">
                            <StackPanel>
                                <TextBlock Text="🟡 Tier 2" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Virtual FS" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="• ~75% compression" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Transparent access" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Custom algorithms" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="(Coming Soon)" FontSize="9" Foreground="#FFA500" FontStyle="Italic" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Tier 3: Ultra -->
                        <Border Grid.Column="2" x:Name="Tier3Border" BorderBrush="{StaticResource SubtextBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6,0,0,0" Cursor="Hand" MouseDown="Tier3_Click">
                            <StackPanel>
                                <TextBlock Text="🔴 Tier 3" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="Ultra Archive" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="• ~90% compression" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Cold storage" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="• Auto warm-up" FontSize="10" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="(Future)" FontSize="9" Foreground="#FF5722" FontStyle="Italic" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Tier Info Panel -->
                    <Border x:Name="TierInfoPanel" Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock x:Name="TierInfoTitle" Text="🟢 Tier 1: Windows Compact" FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TierInfoDescription" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextBrush}">
                                Uses Windows built-in LZX compression. Files remain accessible instantly with no manual mounting. Perfect for games you play frequently. Safe with anti-cheat systems.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <!-- Smart Algorithm Selection (Tier 1 only) -->
                    <CheckBox x:Name="SmartAlgorithmCheckbox" Content="🧠 Use smart algorithm selection (auto-test to find best)" 
                              FontSize="12" Margin="0,12,0,0" IsChecked="True"
                              ToolTip="Tests XPRESS4K, XPRESS8K, XPRESS16K, and LZX on sample files to select the optimal algorithm"
                              Checked="SmartAlgorithmChanged" Unchecked="SmartAlgorithmChanged"/>
                    
                    <!-- Per-File Learning (Advanced) -->
                    <CheckBox x:Name="PerFileLearningCheckbox" Content="🎯 Use per-file-type compression (learns best algorithm for each file type)" 
                              FontSize="12" Margin="0,8,0,0" IsChecked="False"
                              ToolTip="Applies different algorithms to different file types (e.g., LZX for .wav, XPRESS16K for .dds). Learns from each game."/>
                    
                    <!-- Tier 2 Settings Panel -->
                    <StackPanel x:Name="Tier2SettingsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="Cache Size (RAM):" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="CacheSizeSlider" Grid.Column="0" Minimum="512" Maximum="8192" Value="2048" TickFrequency="512" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,16,0" ValueChanged="CacheSizeChanged"/>
                            <TextBlock Grid.Column="1" x:Name="CacheSizeText" Text="2 GB" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Width="60"/>
                        </Grid>
                        
                        <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Mounted Games" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBlock x:Name="MountedStatusText" Text="No games currently mounted" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                                <Button x:Name="UnmountButton" Content="🔓 Unmount" Style="{StaticResource ModernButton}" Margin="0,8,0,0" Click="Unmount_Click" IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Settings Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Compression Settings" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <!-- Backup Retention -->
                    <TextBlock Text="Backup Retention Policy:" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="BackupPolicyComboBox" SelectedIndex="0" Margin="0,0,0,16">
                        <ComboBoxItem Content="🗑️ Delete Immediately (Maximum space savings)" Tag="DeleteImmediately"/>
                        <ComboBoxItem Content="⏱️ Keep for 1 Hour (Paranoid mode)" Tag="Keep1Hour"/>
                        <ComboBoxItem Content="📅 Keep for 1 Day (Very cautious)" Tag="Keep1Day"/>
                        <ComboBoxItem Content="📦 Keep for 1 Week (Not recommended)" Tag="Keep1Week"/>
                        <ComboBoxItem Content="♾️ Keep Permanently (Wastes space!)" Tag="KeepPermanent"/>
                    </ComboBox>
                    
                    <!-- Media Files Option -->
                    <CheckBox x:Name="CompressMediaCheckBox" Content="Attempt to compress media files (images, video, audio)" FontSize="13" Margin="0,0,0,8" Unchecked="CompressMediaChanged" Checked="CompressMediaChanged"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="20,0,0,16">
                        Note: Most media files (JPEG, MP4, MP3) are already compressed. However, uncompressed formats (BMP, WAV, RAW) can compress 50-80%. If unchecked, we'll still compress BMP and WAV automatically.
                    </TextBlock>
                    
                    <!-- Minimum Savings Threshold -->
                    <TextBlock Text="Minimum Savings Threshold:" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="MinSavingsSlider" Grid.Column="0" Minimum="0" Maximum="20" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,16,0" ValueChanged="MinSavingsChanged"/>
                        <TextBlock Grid.Column="1" x:Name="MinSavingsText" Text="5%" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Width="40"/>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,0">
                        Files will only be compressed if they save at least this percentage to avoid wasting time on low-benefit files.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- File Selection Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="File Selection" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="FilePathTextBox" Grid.Column="0" IsReadOnly="True" VerticalAlignment="Center" Padding="8" Margin="0,0,8,0" Text="No files selected"/>
                        <Button x:Name="BrowseFileButton" Grid.Column="1" Content="📄 Browse File" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="BrowseFile_Click"/>
                        <Button x:Name="BrowseFolderButton" Grid.Column="2" Content="📁 Browse Folder" Style="{StaticResource ModernButton}" Click="BrowseFolder_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Action Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Button x:Name="CompressButton" Content="🗜️ Start Compression" Style="{StaticResource SuccessButton}" FontSize="16" Padding="20,12" Click="Compress_Click" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- Progress Card -->
            <Border Style="{StaticResource Card}" x:Name="ProgressCard" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Compression Progress" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <TextBlock x:Name="CurrentFileText" Text="Processing: example.txt" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    
                    <ProgressBar x:Name="CompressionProgressBar" Height="24" Margin="0,0,0,16" Foreground="{DynamicResource AccentBrush}"/>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Files Processed" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            <TextBlock x:Name="FilesProcessedText" Text="0 / 0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Space Saved" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            <TextBlock x:Name="SpaceSavedText" Text="0 MB" FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Compression Ratio" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                            <TextBlock x:Name="CompressionRatioText" Text="0%" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Grid>
                    
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Files Skipped:" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="FilesSkippedText" Text="0" FontSize="20" FontWeight="Bold" Foreground="#FFA500"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
