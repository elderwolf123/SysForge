<UserControl x:Class="RamOptimizerUI.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Page Title -->
            <TextBlock Text="⚡ Performance" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <!-- Plugin Info Card -->
            <Border Style="{StaticResource Card}" Background="#1E2A3A" BorderBrush="#667eea" BorderThickness="2">
                <StackPanel>
                    <TextBlock Text="🔌 Hardware Plugin" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Plugin:" FontSize="14" FontWeight="Sem iBold" Foreground="{StaticResource TextBrush}" Margin="0,0,12,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PluginNameText" Text="Loading..." FontSize="14" Foreground="#667eea" Margin="0,0,0,8"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Device:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DeviceTypeText" Text="Loading..." FontSize="14" Foreground="#667eea"/>
                    </Grid>
                    
                    <TextBlock Text="Supported Features:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="FeatureCoresText" Text="✓ CPU Core Control" FontSize="13" Foreground="#4CAF50" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FeatureBatteryText" Text="✓ Battery Charge Limit" FontSize="13" Foreground="#4CAF50" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FeaturePerformanceText" Text="✓ Performance Modes" FontSize="13" Foreground="#4CAF50" Margin="0,0,0,4"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="FeatureGpuText" Text="✓ GPU Mode Switching" FontSize="13" Foreground="#4CAF50" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FeatureTempText" Text="✓ Temperature Monitoring" FontSize="13" Foreground="#4CAF50" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FeatureFanText" Text="✓ Fan Control" FontSize="13" Foreground="#4CAF50" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Performance Mode Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Performance Mode" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Control ASUS performance profiles and Windows power plans" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Current Mode:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CurrentPerfModeText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                    
                    <UniformGrid Columns="3" Rows="1">
                        <Button Content="🔇 Silent" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="1" Click="SetPerformanceMode_Click"/>
                        <Button Content="⚖️ Balanced" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="0" Click="SetPerformanceMode_Click"/>
                        <Button Content="🚀 Turbo" Style="{StaticResource SuccessButton}" Margin="0,0,0,0" Tag="3" Click="SetPerformanceMode_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- GPU Mode Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="GPU Mode" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Switch between iGPU and dGPU configurations (requires restart)" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Current Mode:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CurrentGpuModeText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                    
                    <UniformGrid Columns="3" Rows="1">
                        <Button Content="🌱 Eco" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="0" Click="SetGpuMode_Click"/>
                        <Button Content="⚡ Standard" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="1" Click="SetGpuMode_Click"/>
                        <Button Content="🔥 Ultimate" Style="{StaticResource SuccessButton}" Margin="0,0,0,0" Tag="2" Click="SetGpuMode_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Battery Limit Control Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Battery Charge Limit" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Set maximum battery charge level to preserve battery health" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Current Limit:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CurrentBatteryLimitText" Text="100%" FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                    
                    <!-- Slider -->
                    <TextBlock Text="Set New Limit:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        
                        <Slider x:Name="BatteryLimitSlider" Minimum="60" Maximum="100" Value="80" 
                                TickFrequency="5" IsSnapToTickEnabled="True" 
                                Margin="0,0,10,0" VerticalAlignment="Center"
                                ValueChanged="BatteryLimitSlider_ValueChanged"/>
                        <TextBlock x:Name="BatteryLimitSliderText" Grid.Column="1" Text="80%" FontSize="16" 
                                   Foreground="{StaticResource AccentBrush}" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Preset Buttons -->
                    <TextBlock Text="Quick Presets:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                        <Button Content="60% (Storage)" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="60" Click="SetBatteryLimitPreset_Click"/>
                        <Button Content="80% (Daily)" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="80" Click="SetBatteryLimitPreset_Click"/>
                        <Button Content="100% (Full)" Style="{StaticResource SuccessButton}" Margin="0,0,0,0" Tag="100" Click="SetBatteryLimitPreset_Click"/>
                    </UniformGrid>
                    
                    <!-- Apply Button -->
                    <Button Content="Apply Battery Limit" Style="{StaticResource SuccessButton}" Click="ApplyBatteryLimit_Click"/>
                    
                    <TextBlock Text="⚠️ Changes require app to run on startup for persistence" FontSize="12" 
                               Foreground="{StaticResource WarningBrush}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- CPU Core Control Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="CPU Core Control" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Enable/Disable P-cores and E-cores (Requires Restart)" FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20"/>
                    
                    <!-- CPU Info -->
                    <TextBlock Text="Detected CPU:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CpuInfoText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="Max Cores:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="MaxCoresText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="Current Configuration:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="CurrentCoresText" Text="Loading..." FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>
                    
                    <!-- P-Core Slider -->
                    <TextBlock Text="P-Cores (Performance):" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="PCoreSlider" Minimum="1" Maximum="8" Value="4" 
                                TickFrequency="1" IsSnapToTickEnabled="True" 
                                Margin="0,0,10,0" VerticalAlignment="Center"
                                ValueChanged="PCoreSlider_ValueChanged"/>
                        <TextBlock x:Name="PCoreSliderText" Grid.Column="1" Text="4" FontSize="16" 
                                   Foreground="{StaticResource AccentBrush}" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- E-Core Slider -->
                    <TextBlock Text="E-Cores (Efficiency):" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ECoreSlider" Minimum="0" Maximum="16" Value="8" 
                                TickFrequency="1" IsSnapToTickEnabled="True" 
                                Margin="0,0,10,0" VerticalAlignment="Center"
                                ValueChanged="ECoreSlider_ValueChanged"/>
                        <TextBlock x:Name="ECoreSliderText" Grid.Column="1" Text="8" FontSize="16" 
                                   Foreground="{StaticResource AccentBrush}" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Presets -->
                    <TextBlock Text="Quick Presets:" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                        <Button Content="All Cores" Style="{StaticResource SuccessButton}" Margin="0,0,8,0" Tag="all" Click="SetCorePreset_Click"/>
                        <Button Content="P-Only" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Tag="ponly" Click="SetCorePreset_Click"/>
                        <Button Content="Balanced" Style="{StaticResource ModernButton}" Margin="0,0,0,0" Tag="balanced" Click="SetCorePreset_Click"/>
                    </UniformGrid>
                    
                    <!-- Apply Button -->
                    <Button Content="Apply Core Configuration" Style="{StaticResource DangerButton}" Click="ApplyCoreConfig_Click"/>
                    <TextBlock Text="⚠️ RESTART REQUIRED for changes to take effect" FontSize="12" 
                               Foreground="{StaticResource WarningBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- CPU Optimization -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="CPU Optimization" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <Button Content="🚀 Optimize CPU for Target Processes" Style="{StaticResource SuccessButton}" 
                           Click="OptimizeCpu_Click" Padding="20,12" FontSize="16" Margin="0,0,0,20"/>
                </StackPanel>
            </Border>

            <!-- GPU Optimization -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="GPU Optimization" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                    <Button Content="🎮 Optimize GPU for Target Processes" Style="{StaticResource SuccessButton}" 
                           Click="OptimizeGpu_Click" Padding="20,12" FontSize="16" Margin="0,0,0,20"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
