<UserControl x:Class="RamOptimizerUI.Views.PowerProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Page Title -->
            <TextBlock Text="⚡ Power Profiles" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <!-- Preset Profiles Card -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <TextBlock Text="Power Profiles" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Select a preset profile or customize settings below" FontSize="13" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,20"/>
                    
                    <ComboBox x:Name="ProfileComboBox" FontSize="14" Padding="10" Margin="0,0,0,16"
                              SelectionChanged="ProfileComboBox_SelectionChanged"/>
                    
                    <TextBlock x:Name="ProfileDescriptionText" FontSize="13" Foreground="{DynamicResource SubtextBrush}" 
                               TextWrapping="Wrap" Margin="0,0,0,16"/>
                </StackPanel>
            </Border>

            <!-- P/E Core Configuration Card -->
            <Border Style="{DynamicResource Card}" x:Name="CoreConfigCard">
                <StackPanel>
                    <TextBlock Text="CPU Core Configuration" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="Customize P-cores and E-cores (auto-set by profile, but you can override)" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,16"/>
                    
                    <!-- P-Cores -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="P-Cores:" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="14"/>
                        <ComboBox Grid.Column="1" x:Name="PCoreComboBox" FontSize="14" Padding="10" 
                                  SelectionChanged="PCoreComboBox_SelectionChanged"/>
                    </Grid>
                    
                    <!-- E-Cores -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="E-Cores:" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" FontSize="14"/>
                        <ComboBox Grid.Column="1" x:Name="ECoreComboBox" FontSize="14" Padding="10"
                                  SelectionChanged="ECoreComboBox_SelectionChanged"/>
                    </Grid>
                    
                    <TextBlock Text="⚠️ Core changes require system restart to take effect" FontSize="11" Foreground="#FFA500" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- I/O Priority Card -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <TextBlock Text="I/O Priority" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="Set disk I/O priority for file operations (auto-set by profile, but you can override)" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💾 Low" FontSize="12" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="⚡ High" FontSize="12" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>
                    
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" x:Name="IOPrioritySlider" Minimum="0" Maximum="3" Value="2" 
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,10,0"
                                ValueChanged="IOPrioritySlider_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="IOPriorityText" Text="Normal" FontSize="14" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Width="80"/>
                    </Grid>
                    
                    <TextBlock Text="Higher I/O priority = faster file transfers and disk operations" FontSize="11" Foreground="{DynamicResource SubtextBrush}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Power/Performance Level Card -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <TextBlock Text="Power/Performance Level" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="Overall power vs. performance balance (from selected profile)" FontSize="12" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💾 Power Saving" FontSize="12" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="⚡ Performance" FontSize="12" Foreground="{DynamicResource SubtextBrush}" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="PowerLevelSlider" Grid.Column="0" Minimum="0" Maximum="100" Value="50" 
                                TickFrequency="25" IsSnapToTickEnabled="True" Margin="0,5,10,0" IsEnabled="False"/>
                        <TextBlock Grid.Column="1" x:Name="PowerLevelText" Text="50" FontSize="14" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Apply Button -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <Button Content="⚡ Apply Profile with Custom Settings" Style="{DynamicResource SuccessButton}" 
                           Click="ApplyProfile_Click" Padding="20,12" HorizontalAlignment="Left" FontSize="14"/>
                    <TextBlock Text="This will apply the selected profile with your custom P/E core and I/O priority settings" 
                               FontSize="11" Foreground="{DynamicResource SubtextBrush}" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
