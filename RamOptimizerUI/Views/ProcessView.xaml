<UserControl x:Class="RamOptimizerUI.Views.ProcessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Page Title -->
            <TextBlock Text="🔧 Processes" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,30"/>
            
            <!-- Target Processes Card -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <TextBlock Text="Target Processes" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="ProcessNameTextBox" Style="{DynamicResource ModernTextBox}" 
                                Grid.Column="0" Margin="0,0,10,0"
                                Text="notepad.exe"/>
                        
                        <Button Grid.Column="1" Content="Add Process" Style="{DynamicResource SuccessButton}" 
                               Click="AddTargetProcess_Click" Width="120"/>
                    </Grid>

                    <ListBox x:Name="TargetProcessesListBox" Style="{DynamicResource ModernListBox}" 
                            Height="150" Margin="0,16,0,0"/>

                    <Button Content="Remove Selected" Style="{DynamicResource DangerButton}" 
                           Click="RemoveTargetProcess_Click" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Termination Levels Card -->
            <Border Style="{DynamicResource Card}">
                <StackPanel>
                    <TextBlock Text="Memory Termination Levels" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Aggressively free memory by terminating processes" FontSize="13" Foreground="{DynamicResource SubtextBrush}" Margin="0,0,0,16"/>
                    
                    <UniformGrid Columns="4" Rows="2">
                        <Button Content="Level 1 (Mild)" Style="{DynamicResource ModernButton}" Margin="0,0,8,8" Tag="1" Click="TerminateLevel_Click"/>
                        <Button Content="Level 2" Style="{DynamicResource ModernButton}" Margin="0,0,8,8" Tag="2" Click="TerminateLevel_Click"/>
                        <Button Content="Level 3" Style="{DynamicResource ModernButton}" Margin="0,0,8,8" Tag="3" Click="TerminateLevel_Click"/>
                        <Button Content="Level 4" Style="{DynamicResource ModernButton}" Margin="0,0,0,8" Tag="4" Click="TerminateLevel_Click"/>
                        <Button Content="Level 5" Style="{DynamicResource DangerButton}" Margin="0,0,8,0" Tag="5" Click="TerminateLevel_Click"/>
                        <Button Content="Level 6" Style="{DynamicResource DangerButton}" Margin="0,0,8,0" Tag="6" Click="TerminateLevel_Click"/>
                        <Button Content="Level 7 (Extreme)" Style="{DynamicResource DangerButton}" Margin="0,0,8,0" Tag="7" Click="TerminateLevel_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
