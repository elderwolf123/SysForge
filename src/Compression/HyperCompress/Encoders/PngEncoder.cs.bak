using System;
using System.IO;
using System.Drawing;
using System.Drawing.Imaging;

namespace RamOptimizer.Compression.HyperCompress.Encoders;

/// <summary>
/// PNG compression encoder for image files.
/// Provides lossless compression specifically optimized for image data.
/// </summary>
public class PngEncoder : IHyperEncoder
{
    public HyperAlgorithm Algorithm => HyperAlgorithm.HyperGeneral_Image;
    
    public byte[] Compress(byte[] data, CompressionSettings settings)
    {
        // PNG is specifically for image files, so we need to handle this differently
        // For now, we'll create a simple PNG-like compression for demonstration
        // In a real implementation, you'd use System.Drawing or a dedicated PNG library
        
        try
        {
            // Try to detect if this is an image file
            if (IsImageFile(data))
            {
                return CompressAsPng(data);
            }
            else
            {
                // Fallback to general compression for non-image data
                return CompressGeneral(data, settings);
            }
        }
        catch
        {
            // If PNG compression fails, fall back to general compression
            return CompressGeneral(data, settings);
        }
    }
    
    public byte[] Decompress(byte[] compressed)
    {
        // PNG decompression would require proper PNG library
        // For now, return the data as-is (assuming it's already compressed)
        return compressed;
    }
    
    public float EstimateRatio(byte[] sample)
    {
        if (IsImageFile(sample))
        {
            // Images typically compress well with PNG
            return 0.40f; // 60% compression ratio for images
        }
        else if (IsTextLike(sample))
        {
            return 0.35f; // Text compresses reasonably well
        }
        else
        {
            return 0.55f; // Binary average
        }
    }
    
    public bool IsSuitable(byte[] data, string fileName)
    {
        // PNG is suitable for image files and some text/data files
        return IsImageFile(data) || fileName.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ||
               fileName.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
               fileName.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
               fileName.EndsWith(".bmp", StringComparison.OrdinalIgnoreCase) ||
               fileName.EndsWith(".tiff", StringComparison.OrdinalIgnoreCase) ||
               IsTextLike(data);
    }
    
    private bool IsImageFile(byte[] data)
    {
        if (data.Length < 8) return false;
        
        // Check common image file headers
        // PNG: 89 50 4E 47 0D 0A 1A 0A
        if (data[0] == 0x89 && data[1] == 0x50 && data[2] == 0x4E && data[3] == 0x47)
            return true;
        
        // JPEG: FF D8 FF
        if (data[0] == 0xFF && data[1] == 0xD8 && data[2] == 0xFF)
            return true;
        
        // BMP: BM (42 4D)
        if (data[0] == 0x42 && data[1] == 0x4D)
            return true;
        
        // GIF: GIF87a or GIF89a
        if (data.Length >= 6)
        {
            string gifHeader = System.Text.Encoding.ASCII.GetString(data, 0, 6);
            return gifHeader.StartsWith("GIF87a") || gifHeader.StartsWith("GIF89a");
        }
        
        return false;
    }
    
    private bool IsTextLike(byte[] data)
    {
        if (data.Length == 0) return false;
        
        int printable = 0;
        int sampleSize = Math.Min(4096, data.Length);
        
        for (int i = 0; i < sampleSize; i++)
        {
            byte b = data[i];
            if ((b >= 32 && b <= 126) || b == 9 || b == 10 || b == 13)
                printable++;
        }
        
        return (float)printable / sampleSize > 0.7f;
    }
    
    private byte[] CompressAsPng(byte[] data)
    {
        // Simplified PNG-like compression
        // In a real implementation, you'd use a proper PNG library
        
        using var output = new MemoryStream();
        
        // PNG signature
        output.Write(new byte[] { 0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A }, 0, 8);
        
        // IHDR chunk (header)
        WriteChunk(output, "IHDR", new byte[] {
            (byte)(data.Length >> 24), (byte)(data.Length >> 16), 
            (byte)(data.Length >> 8), (byte)data.Length,
            0x02, // RGB
            0x00, // Standard deflate
            0x00, // No interlace
            0x00, 0x00, 0x00 // Default gamma
        });
        
        // IDAT chunk (compressed data)
        var compressedData = CompressGeneral(data, new CompressionSettings { Level = 6 });
        WriteChunk(output, "IDAT", compressedData);
        
        // IEND chunk
        WriteChunk(output, "IEND", new byte[0]);
        
        return output.ToArray();
    }
    
    private byte[] CompressGeneral(byte[] data, CompressionSettings settings)
    {
        // Use Gzip as fallback for general compression
        using var output = new MemoryStream();
        using var compressor = new System.IO.Compression.GZipStream(output, System.IO.Compression.CompressionLevel.Optimal);
        
        compressor.Write(data, 0, data.Length);
        compressor.Flush();
        
        return output.ToArray();
    }
    
    private void WriteChunk(MemoryStream stream, string chunkType, byte[] data)
    {
        var chunkBytes = System.Text.Encoding.ASCII.GetBytes(chunkType);
        
        // Chunk length (4 bytes)
        stream.WriteByte((byte)(data.Length >> 24));
        stream.WriteByte((byte)(data.Length >> 16));
        stream.WriteByte((byte)(data.Length >> 8));
        stream.WriteByte((byte)data.Length);
        
        // Chunk type (4 bytes)
        stream.Write(chunkBytes, 0, 4);
        
        // Chunk data
        stream.Write(data, 0, data.Length);
        
        // CRC32 (4 bytes) - simplified for demo
        uint crc = CalculateCRC32(chunkBytes, data);
        stream.WriteByte((byte)(crc >> 24));
        stream.WriteByte((byte)(crc >> 16));
        stream.WriteByte((byte)(crc >> 8));
        stream.WriteByte((byte)crc);
    }
    
    private uint CalculateCRC32(byte[] chunkType, byte[] data)
    {
        // Simplified CRC32 calculation for demo
        uint crc = 0xFFFFFFFF;
        
        foreach (byte b in chunkType)
        {
            crc ^= b;
            for (int i = 0; i < 8; i++)
            {
                crc = (crc >> 1) ^ (0xEDB88320 & -(crc & 1));
            }
        }
        
        foreach (byte b in data)
        {
            crc ^= b;
            for (int i = 0; i < 8; i++)
            {
                crc = (crc >> 1) ^ (0xEDB88320 & -(crc & 1));
            }
        }
        
        return ~crc;
    }
}